<!-- backend/views/edit-promotion.ejs -->
<!-- CORRECTED to use relative image paths for the admin panel -->

<%- include('partials/_header') %>
<%- include('partials/_sidebar') %>

<div class="max-w-4xl mx-auto">
    <!-- Back Navigation Link -->
    <div class="mb-4">
        <a href="<%= adminBase %>/promotions" class="inline-flex items-center text-sm font-medium text-gray-600 hover:text-primary-600 transition-colors">
            <i class="ri-arrow-left-s-line mr-1 text-lg"></i>
            Back to Promotions
        </a>
    </div>

    <!-- Form Card -->
    <div class="card">
        <div class="p-6 border-b border-gray-200">
             <h2 class="text-2xl font-bold text-gray-800"><%= title %></h2>
             <p class="mt-1 text-sm text-gray-500">Manage the details for your promotional campaigns.</p>
        </div>
       
        <form id="promotionForm">
            <div class="p-6 space-y-6">
                <!-- Slug -->
                <div>
                    <label for="slug" class="block text-sm font-medium text-gray-700">Slug (Unique Identifier)</label>
                    <input type="text" id="slug" value="<%= promotion ? promotion.slug : '' %>" required <%= promotion ? 'readonly' : '' %>
                           class="form-input <%= promotion ? 'bg-gray-100 cursor-not-allowed' : '' %>">
                </div>

                <!-- Title (English & Hindi) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="title_en" class="block text-sm font-medium text-gray-700">Title (English)</label>
                        <input type="text" id="title_en" value="<%= promotion ? promotion.title.en : '' %>" required class="form-input">
                    </div>
                    <div>
                        <label for="title_hi" class="block text-sm font-medium text-gray-700">Title (Hindi)</label>
                        <input type="text" id="title_hi" value="<%= promotion ? promotion.title.hi : '' %>" required class="form-input">
                    </div>
                </div>
                
                <!-- Subtitle (English & Hindi) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="subtitle_en" class="block text-sm font-medium text-gray-700">Subtitle (English)</label>
                        <input type="text" id="subtitle_en" value="<%= promotion && promotion.subtitle ? promotion.subtitle.en : '' %>" class="form-input">
                    </div>
                    <div>
                        <label for="subtitle_hi" class="block text-sm font-medium text-gray-700">Subtitle (Hindi)</label>
                        <input type="text" id="subtitle_hi" value="<%= promotion && promotion.subtitle ? promotion.subtitle.hi : '' %>" class="form-input">
                    </div>
                </div>
                
                <!-- Description (English & Hindi) -->
                <div>
                    <label for="description_en" class="block text-sm font-medium text-gray-700">Description (English)</label>
                    <textarea id="description_en" rows="3" required class="form-input"><%= promotion ? promotion.description.en : '' %></textarea>
                </div>
                 <div>
                    <label for="description_hi" class="block text-sm font-medium text-gray-700">Description (Hindi)</label>
                    <textarea id="description_hi" rows="3" required class="form-input"><%= promotion ? promotion.description.hi : '' %></textarea>
                </div>

                 <!-- Details (English & Hindi) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="details_en" class="block text-sm font-medium text-gray-700">Details (English, one per line)</label>
                        <textarea id="details_en" rows="4" class="form-input"><%= promotion && promotion.details && promotion.details.en ? promotion.details.en.join('\n') : '' %></textarea>
                    </div>
                    <div>
                        <label for="details_hi" class="block text-sm font-medium text-gray-700">Details (Hindi, one per line)</label>
                        <textarea id="details_hi" rows="4" class="form-input"><%= promotion && promotion.details && promotion.details.hi ? promotion.details.hi.join('\n') : '' %></textarea>
                    </div>
                </div>

                <!-- CTA & Badge Text (English & Hindi) -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label for="ctaText_en" class="block text-sm font-medium text-gray-700">CTA Button Text (English)</label>
                        <input type="text" id="ctaText_en" value="<%= promotion && promotion.ctaText ? promotion.ctaText.en : '' %>" class="form-input">
                    </div>
                    <div>
                        <label for="ctaText_hi" class="block text-sm font-medium text-gray-700">CTA Button Text (Hindi)</label>
                        <input type="text" id="ctaText_hi" value="<%= promotion && promotion.ctaText ? promotion.ctaText.hi : '' %>" class="form-input">
                    </div>
                     <div>
                        <label for="badgeText_en" class="block text-sm font-medium text-gray-700">Badge Text (English)</label>
                        <input type="text" id="badgeText_en" value="<%= promotion && promotion.badgeText ? promotion.badgeText.en : '' %>" class="form-input">
                    </div>
                    <div>
                        <label for="badgeText_hi" class="block text-sm font-medium text-gray-700">Badge Text (Hindi)</label>
                        <input type="text" id="badgeText_hi" value="<%= promotion && promotion.badgeText ? promotion.badgeText.hi : '' %>" class="form-input">
                    </div>
                </div>
                
                <!-- Image Upload Component -->
                <div>
                    <label class="block text-sm font-medium text-gray-700">Promotion Image</label>
                    <div class="mt-2 flex items-center space-x-6">
                        <div id="image-preview-container" class="shrink-0">
                            <!-- THIS IS THE CORRECTED LINE -->
                            <img id="image-preview" 
                                 src="<%= (promotion && promotion.imageUrl) ? promotion.imageUrl : 'https://via.placeholder.com/128' %>" 
                                 alt="Image preview" 
                                 class="h-32 w-32 object-cover rounded-md">
                        </div>
                        <div class="flex-grow">
                            <input type="hidden" id="imageUrl" value="<%= promotion ? promotion.imageUrl : '' %>">
                            <label for="image-upload-input" class="btn btn-secondary cursor-pointer">
                                <span>Choose Image</span>
                            </label>
                            <input id="image-upload-input" type="file" class="sr-only">
                            <p class="mt-2 text-xs text-gray-500">PNG, JPG, GIF, WEBP up to 5MB.</p>
                            <div id="upload-status" class="mt-2 text-sm"></div>
                        </div>
                    </div>
                </div>

                <!-- Other Fields -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                     <div>
                        <label for="ctaLink" class="block text-sm font-medium text-gray-700">CTA Link</label>
                        <input type="text" id="ctaLink" value="<%= promotion ? promotion.ctaLink : '' %>" class="form-input">
                    </div>
                     <div>
                        <label for="displayOrder" class="block text-sm font-medium text-gray-700">Display Order</label>
                        <input type="number" id="displayOrder" value="<%= promotion ? promotion.displayOrder : 0 %>" class="form-input">
                    </div>
                </div>
            </div>

            <!-- Form Footer -->
            <div class="bg-gray-50 p-4 flex justify-end rounded-b-lg">
                <button type="submit" id="submitButton" class="btn btn-primary">
                    <%= promotion ? 'Update Promotion' : 'Create Promotion' %>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // --- Image Upload Logic ---
    const imageUploadInput = document.getElementById('image-upload-input');
    const imagePreview = document.getElementById('image-preview');
    const imagePathInput = document.getElementById('imageUrl');
    const uploadStatus = document.getElementById('upload-status');

    imageUploadInput.addEventListener('change', async (event) => {
        const file = event.target.files[0];
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = (e) => { imagePreview.src = e.target.result; };
        reader.readAsDataURL(file);
        
        const formData = new FormData();
        formData.append('image', file);
        uploadStatus.textContent = 'Uploading...';
        uploadStatus.className = 'mt-2 text-sm text-gray-600';

        try {
            const token = document.cookie.split('; ').find(row => row.startsWith('token='))?.split('=')[1];
            const response = await fetch('/api/admin/upload', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData,
            });
            const result = await response.json();
            if (!response.ok) throw new Error(result.message || 'Upload failed');
            
            imagePathInput.value = result.filePath;
            imagePreview.src = result.filePath;
            uploadStatus.textContent = 'Upload successful!';
            uploadStatus.className = 'mt-2 text-sm text-green-600 font-medium';
        } catch (error) {
            uploadStatus.textContent = `Error: ${error.message}`;
            uploadStatus.className = 'mt-2 text-sm text-red-600 font-medium';
        }
    });

    // --- Form Submission Logic (unchanged) ---
    const getArrayFromTextarea = (id) => document.getElementById(id).value.split('\n').map(item => item.trim()).filter(Boolean);
    const form = document.getElementById('promotionForm');
    const submitButton = document.getElementById('submitButton');
    const method = '<%= promotion ? "PUT" : "POST" %>';
    const apiEndpoint = '<%= apiEndpoint %>';

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!imagePathInput.value) {
            showToast('Please upload an image for the promotion.', 'error');
            return;
        }

        submitButton.disabled = true;
        submitButton.textContent = 'Saving...';

        const formData = {
            slug: document.getElementById('slug').value,
            title: { en: document.getElementById('title_en').value, hi: document.getElementById('title_hi').value },
            subtitle: { en: document.getElementById('subtitle_en').value, hi: document.getElementById('subtitle_hi').value },
            description: { en: document.getElementById('description_en').value, hi: document.getElementById('description_hi').value },
            ctaText: { en: document.getElementById('ctaText_en').value, hi: document.getElementById('ctaText_hi').value },
            badgeText: { en: document.getElementById('badgeText_en').value, hi: document.getElementById('badgeText_hi').value },
            details: { en: getArrayFromTextarea('details_en'), hi: getArrayFromTextarea('details_hi') },
            imageUrl: imagePathInput.value,
            ctaLink: document.getElementById('ctaLink').value,
            displayOrder: parseInt(document.getElementById('displayOrder').value) || 0
        };
        
        try {
            const token = document.cookie.split('; ').find(row => row.startsWith('token='))?.split('=')[1];
            const response = await fetch(apiEndpoint, {
                method: method,
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(formData)
            });

            const result = await response.json();
            if (!response.ok) throw new Error(result.message || 'An error occurred.');

            showToast('Promotion saved successfully!', 'success');

            setTimeout(() => {
                window.location.href = '<%= adminBase %>/promotions';
            }, 1000);

        } catch (error) {
            showToast(error.message, 'error');
            submitButton.disabled = false;
            submitButton.innerHTML = '<%= promotion ? "Update Promotion" : "Create Promotion" %>';
        }
    });
</script>

<%- include('partials/_footer') %>