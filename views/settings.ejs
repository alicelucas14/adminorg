<!-- backend/views/settings.ejs -->
<!-- CORRECTED to use relative image paths for the admin panel -->

<%- include('partials/_header') %>
<%- include('partials/_sidebar') %>

<div class="max-w-4xl mx-auto">
    <!-- Form Card -->
    <div class="card">
        <form id="settingsForm">
            <div class="p-6 border-b border-gray-200">
                <h2 class="text-2xl font-bold text-gray-800"><%= title %></h2>
                <p class="mt-1 text-sm text-gray-500">Manage global settings for the entire website from one place.</p>
            </div>

            <div class="divide-y divide-gray-200">
                <!-- Download & Media Section -->
                <div class="p-6 space-y-6">
                    <h3 class="text-lg font-semibold text-gray-800">Site Media & Downloads</h3>
                    
                    <!-- Logo Upload -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700">Logo</label>
                        <div class="mt-2 flex items-center space-x-6">
                            <div class="shrink-0">
                                <!-- THIS IS THE CORRECTED LINE -->
                                <img id="logo-preview" 
                                     src="<%= (settings && settings.logoUrl) ? settings.logoUrl : 'https://via.placeholder.com/128' %>" 
                                     alt="Logo preview" 
                                     class="h-24 w-24 object-contain rounded-md bg-gray-50 p-1 border">
                            </div>
                            <div class="flex-grow">
                                <input type="hidden" id="logoUrl" value="<%= settings ? settings.logoUrl : '' %>">
                                <label for="logo-upload-input" class="btn btn-secondary cursor-pointer">
                                    <span>Upload Logo</span>
                                </label>
                                <input id="logo-upload-input" type="file" class="sr-only">
                                <p class="mt-2 text-xs text-gray-500">PNG, JPG, SVG, WEBP up to 5MB.</p>
                                <div id="logo-upload-status" class="mt-2 text-sm"></div>
                            </div>
                        </div>
                    </div>

                    <!-- QR Code Upload -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700">QR Code Image</label>
                        <div class="mt-2 flex items-center space-x-6">
                             <div class="shrink-0">
                                <!-- THIS IS THE CORRECTED LINE -->
                                <img id="qr-preview" 
                                     src="<%= (settings && settings.qrCodeImageUrl) ? settings.qrCodeImageUrl : 'https://via.placeholder.com/128' %>" 
                                     alt="QR Code preview" 
                                     class="h-24 w-24 object-contain rounded-md bg-gray-50 p-1 border">
                            </div>
                            <div class="flex-grow">
                                <input type="hidden" id="qrCodeImageUrl" value="<%= settings ? settings.qrCodeImageUrl : '' %>">
                                <label for="qr-upload-input" class="btn btn-secondary cursor-pointer">
                                    <span>Upload QR Code</span>
                                </label>
                                <input id="qr-upload-input" type="file" class="sr-only">
                                <p class="mt-2 text-xs text-gray-500">PNG, JPG, SVG, WEBP up to 5MB.</p>
                                <div id="qr-upload-status" class="mt-2 text-sm"></div>
                            </div>
                        </div>
                    </div>

                    <!-- APK Link -->
                    <div>
                        <label for="apkDownloadLink" class="block text-sm font-medium text-gray-700">APK Download Link</label>
                        <input type="text" id="apkDownloadLink" value="<%= settings ? settings.apkDownloadLink : '' %>" required class="form-input">
                    </div>
                </div>

                <!-- Social & Support Links Section -->
                <div class="p-6 space-y-4">
                     <h3 class="text-lg font-semibold text-gray-800">Social & Support Links</h3>
                     <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div><label for="telegramUrl" class="block text-sm font-medium">Telegram URL</label><input type="url" id="telegramUrl" value="<%= settings ? settings.telegramUrl : '' %>" class="form-input"></div>
                        <div><label for="whatsappUrl" class="block text-sm font-medium">WhatsApp URL</label><input type="url" id="whatsappUrl" value="<%= settings ? settings.whatsappUrl : '' %>" class="form-input"></div>
                        <div><label for="instagramUrl" class="block text-sm font-medium">Instagram URL</label><input type="url" id="instagramUrl" value="<%= settings ? settings.instagramUrl : '' %>" class="form-input"></div>
                        <div><label for="facebookUrl" class="block text-sm font-medium">Facebook URL</label><input type="url" id="facebookUrl" value="<%= settings ? settings.facebookUrl : '' %>" class="form-input"></div>
                        <div><label for="youtubeUrl" class="block text-sm font-medium">YouTube URL</label><input type="url" id="youtubeUrl" value="<%= settings ? settings.youtubeUrl : '' %>" class="form-input"></div>
                        <div><label for="twitterUrl" class="block text-sm font-medium">Twitter (X) URL</label><input type="url" id="twitterUrl" value="<%= settings ? settings.twitterUrl : '' %>" class="form-input"></div>
                        <div><label for="liveChatUrl" class="block text-sm font-medium">Live Chat URL</label><input type="url" id="liveChatUrl" value="<%= settings ? settings.liveChatUrl : '' %>" class="form-input"></div>
                     </div>
                </div>
            </div>

            <!-- Form Footer -->
            <div class="bg-gray-50 p-4 flex justify-between items-center rounded-b-lg">
                <div id="statusMessage" class="text-sm font-medium"></div>
                <button type="submit" id="submitButton" class="btn btn-primary">
                    Save Settings
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // --- REUSABLE UPLOAD HANDLER ---
    async function handleImageUpload(event, previewEl, pathInputEl, statusEl) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = (e) => { previewEl.src = e.target.result; };
        reader.readAsDataURL(file);
        
        const formData = new FormData();
        formData.append('image', file);
        statusEl.textContent = 'Uploading...';
        statusEl.className = 'mt-2 text-sm text-gray-600';

        try {
            const token = document.cookie.split('; ').find(row => row.startsWith('token='))?.split('=')[1];
            const response = await fetch('/api/admin/upload', {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` },
                body: formData,
            });
            const result = await response.json();
            if (!response.ok) throw new Error(result.message || 'Upload failed');
            
            pathInputEl.value = result.filePath;
            previewEl.src = result.filePath;
            statusEl.textContent = 'Upload successful!';
            statusEl.className = 'mt-2 text-sm text-green-600 font-medium';
        } catch (error) {
            statusEl.textContent = `Error: ${error.message}`;
            statusEl.className = 'mt-2 text-sm text-red-600 font-medium';
        }
    }

    // --- SETUP EVENT LISTENERS FOR EACH UPLOAD ---
    const logoUploadInput = document.getElementById('logo-upload-input');
    logoUploadInput.addEventListener('change', (event) => {
        handleImageUpload(
            event,
            document.getElementById('logo-preview'),
            document.getElementById('logoUrl'),
            document.getElementById('logo-upload-status')
        );
    });

    const qrUploadInput = document.getElementById('qr-upload-input');
    qrUploadInput.addEventListener('change', (event) => {
        handleImageUpload(
            event,
            document.getElementById('qr-preview'),
            document.getElementById('qrCodeImageUrl'),
            document.getElementById('qr-upload-status')
        );
    });

    // --- FORM SUBMISSION LOGIC (unchanged) ---
    const form = document.getElementById('settingsForm');
    const submitButton = document.getElementById('submitButton');
    const statusMessageDiv = document.getElementById('statusMessage');
    const apiEndpoint = '<%= apiEndpoint %>';

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submitButton.disabled = true;
        submitButton.textContent = 'Saving...';
        statusMessageDiv.textContent = '';
        statusMessageDiv.className = 'text-sm font-medium';

        const formData = {
            logoUrl: document.getElementById('logoUrl').value,
            qrCodeImageUrl: document.getElementById('qrCodeImageUrl').value,
            apkDownloadLink: document.getElementById('apkDownloadLink').value,
            telegramUrl: document.getElementById('telegramUrl').value,
            whatsappUrl: document.getElementById('whatsappUrl').value,
            instagramUrl: document.getElementById('instagramUrl').value,
            facebookUrl: document.getElementById('facebookUrl').value,
            youtubeUrl: document.getElementById('youtubeUrl').value,
            twitterUrl: document.getElementById('twitterUrl').value,
            liveChatUrl: document.getElementById('liveChatUrl').value
        };
        
        try {
            const token = document.cookie.split('; ').find(row => row.startsWith('token='))?.split('=')[1];
            
            const response = await fetch(apiEndpoint, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(formData)
            });

            const result = await response.json();
            if (!response.ok) throw new Error(result.message || 'An error occurred.');

            statusMessageDiv.textContent = 'Settings saved successfully!';
            statusMessageDiv.classList.add('text-green-600');
            setTimeout(() => statusMessageDiv.textContent = '', 3000);

        } catch (error) {
            statusMessageDiv.textContent = error.message;
            statusMessageDiv.classList.add('text-red-600');
        } finally {
            submitButton.disabled = false;
            submitButton.textContent = 'Save Settings';
        }
    });
</script>

<%- include('partials/_footer') %>