<!-- backend/views/partials/_sidebar.ejs -->

<!-- 
  CHANGED: The sidebar is now `fixed` to the viewport. 
  `h-screen` ensures it always takes the full height.
-->
<div class="fixed h-screen w-64 bg-gray-900 text-gray-300 p-4 flex flex-col">
    <!-- Logo/Brand Header -->
    <div class="mb-8 text-center flex-shrink-0">
        <a href="<%= adminBase %>/dashboard" class="inline-flex items-center gap-2 text-2xl font-bold text-white transition-opacity hover:opacity-80">
            <i class="ri-shield-flash-line text-yellow-400"></i>
            <span class="text-yellow-400">UU7Game</span>
        </a>
        <p class="text-xs text-gray-500 mt-1">Admin Panel</p>
    </div>

    <!-- 
      Navigation
      ADDED: `overflow-y-auto` allows the list of links to scroll independently 
      if they become too numerous for the screen height. `pr-2` adds space for the scrollbar.
    -->
    <nav class="flex-grow overflow-y-auto pr-2">
        <span class="px-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Menu</span>
        <ul class="mt-2 space-y-1">
            <li>
                <a href="<%= adminBase %>/dashboard" class="flex items-center p-2 rounded-md transition-colors <%= page === 'dashboard' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-dashboard-3-line mr-3 w-5 text-center"></i> Dashboard
                </a>
            </li>
            <li>
                <a href="<%= adminBase %>/games" class="flex items-center p-2 rounded-md transition-colors <%= page === 'games' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-gamepad-line mr-3 w-5 text-center"></i> Games
                </a>
            </li>
            <li>
                <a href="<%= adminBase %>/blog" class="flex items-center p-2 rounded-md transition-colors <%= page === 'blog' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-article-line mr-3 w-5 text-center"></i> Blog Posts
                </a>
            </li>
            <li>
                <a href="<%= adminBase %>/reviews" class="flex items-center p-2 rounded-md transition-colors <%= page === 'reviews' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-star-line mr-3 w-5 text-center"></i> Reviews
                </a>
            </li>
            <li>
                <a href="<%= adminBase %>/pages" class="flex items-center p-2 rounded-md transition-colors <%= page === 'pages' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-file-text-line mr-3 w-5 text-center"></i> Pages
                </a>
            </li>
            <li>
                <a href="<%= adminBase %>/promotions" class="flex items-center p-2 rounded-md transition-colors <%= page === 'promotions' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-gift-line mr-3 w-5 text-center"></i> Promotions
                </a>
            </li>
            <li>
                <a href="<%= adminBase %>/link-checker" class="flex items-center p-2 rounded-md transition-colors <%= page === 'link-checker' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-link-unlink mr-3 w-5 text-center"></i> Link Checker
                </a>
            </li>
        </ul>
        
        <span class="px-2 mt-6 block text-xs font-semibold text-gray-500 uppercase tracking-wider">Configuration</span>
        <ul class="mt-2 space-y-1">
             <li>
                <a href="<%= adminBase %>/settings" class="flex items-center p-2 rounded-md transition-colors <%= page === 'settings' ? 'bg-primary-600 text-white shadow-sm' : 'hover:bg-gray-800' %>">
                    <i class="ri-settings-3-line mr-3 w-5 text-center"></i> Site Settings
                </a>
            </li>
        </ul>
    </nav>

    <!-- Sidebar Footer (User Info) -->
    <div class="mt-auto flex-shrink-0 border-t border-gray-700 pt-4">
         <div class="flex items-center">
            <i class="ri-user-circle-line text-3xl text-gray-400"></i>
            <div class="ml-3">
                <p class="text-sm font-medium text-white"><%= user.username %></p>
                <button id="logoutButton" class="text-xs text-gray-400 hover:text-red-400 hover:underline transition-colors">Log Out</button>
            </div>
         </div>
    </div>
</div>

<!-- 
  Main Content Area
  CHANGED: Added `ml-64` to offset the main content area, preventing it
  from being hidden underneath the fixed sidebar.
-->
<div class="ml-64 flex-1 flex flex-col">
    <!-- Header Bar for Main Content -->
    <header class="bg-white border-b border-gray-200 p-4 sticky top-0 z-10">
        <div class="flex justify-between items-center">
             <h1 class="text-2xl font-bold text-gray-800 capitalize"><%= title || page %></h1>
             <!-- Breadcrumbs or other header content could go here -->
        </div>
    </header>
    
    <!-- Main Content Body -->
    <main class="flex-1 p-6">