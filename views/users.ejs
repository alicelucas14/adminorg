<!-- backend/views/users.ejs -->
<%- include('partials/_header') %>
<%- include('partials/_sidebar') %>

<!-- Page Header & Actions -->
<div class="mb-6 md:flex md:justify-between md:items-center">
    <div>
        <h2 class="text-3xl font-bold text-gray-800">User Management</h2>
        <p class="text-gray-500 mt-1">Monitor, assign roles, and manage all users registered on the platform.</p>
    </div>
</div>

<!-- Search and Filter Bar -->
<div class="mb-4 card p-4 flex justify-between items-center">
    <div class="relative w-full max-w-sm">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="ri-search-line text-gray-400"></i>
        </div>
        <input type="text" id="search-input" placeholder="Search by username..." class="form-input !mt-0 pl-10 w-full">
    </div>
</div>

<!-- Users Table Card -->
<div class="card overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
            <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date Registered</th>
                <th scope="col" class="relative px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Actions
                </th>
            </tr>
        </thead>
        <tbody id="users-table-body" class="bg-white divide-y divide-gray-200">
            <!-- Loading State -->
            <tr id="loadingRow">
                <td colspan="4" class="px-6 py-12 text-center text-gray-500">
                    <div class="flex justify-center items-center">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary-600"></div>
                        <span class="ml-3">Loading users...</span>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
    
    <!-- Pagination Controls -->
    <div id="pagination-controls" class="p-4 flex items-center justify-between border-t border-gray-200"></div>
</div>

<script>
    // --- STATE & DOM ELEMENTS ---
    const apiEndpoint = '<%= apiEndpoint %>';
    const currentUserId = '<%= user._id.toString() %>';
    let currentPage = 1, totalPages = 1;
    let currentSearchQuery = '', debounceTimer; 

    const tableBody = document.getElementById('users-table-body');
    const searchInput = document.getElementById('search-input');
    const loadingRow = document.getElementById('loadingRow');
    const paginationControls = document.getElementById('pagination-controls');

    // --- HELPER & RENDER FUNCTIONS ---
    const getToken = () => document.cookie.split('; ').find(row => row.startsWith('token='))?.split('=')[1] || null;

    const renderTable = (users) => {
        tableBody.innerHTML = '';
        if (users.length === 0) { 
            tableBody.innerHTML = `<tr><td colspan="4" class="px-6 py-12 text-center text-gray-500">No users found.</td></tr>`; 
            return; 
        }
        
        users.forEach(userItem => {
            const row = document.createElement('tr');
            row.id = `row-${userItem._id}`;
            const username = userItem.username;
            const role = userItem.role;
            const registrationDate = userItem.createdAt 
                ? new Date(userItem.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
                : 'N/A';
            const isSelf = userItem._id === currentUserId;

            // Role selection HTML
            let roleSelect = '';
            if (isSelf) {
                roleSelect = `<span class="px-2.5 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800 uppercase">${role} (You)</span>`;
            } else {
                roleSelect = `
                    <select class="form-select !mt-0 py-1 px-2 border border-gray-300 rounded text-sm role-change-select" data-id="${userItem._id}">
                        <option value="user" ${role === 'user' ? 'selected' : ''}>User</option>
                        <option value="admin" ${role === 'admin' ? 'selected' : ''}>Admin</option>
                    </select>
                `;
            }

            row.innerHTML = `
                <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                        <div class="h-10 w-10 flex-shrink-0 flex items-center justify-center rounded-full bg-primary-100 text-primary-700 font-bold text-lg">
                            ${username.charAt(0).toUpperCase()}
                        </div>
                        <div class="ml-4">
                            <div class="text-sm font-semibold text-gray-900">${username}</div>
                            <div class="text-xs text-gray-500 font-mono">${userItem._id}</div>
                        </div>
                    </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    ${roleSelect}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                    ${registrationDate}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    ${isSelf ? 
                        `<span class="text-gray-400 italic">Self</span>` : 
                        `<button class="text-red-600 hover:text-red-900 delete-user-btn font-semibold" data-id="${userItem._id}">Delete</button>`
                    }
                </td>
            `;
            tableBody.appendChild(row);
        });
    };

    const renderPagination = (totalItems) => {
        paginationControls.innerHTML = '';
        if (totalPages <= 1) return;
        let paginationHTML = `
            <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                <div><p class="text-sm text-gray-700">Showing <span class="font-medium">${(currentPage - 1) * 10 + 1}</span> to <span class="font-medium">${Math.min(currentPage * 10, totalItems)}</span> of <span class="font-medium">${totalItems}</span> results</p></div>
                <div><nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination"><button id="prev-desktop" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">Prev</button><span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">Page ${currentPage} of ${totalPages}</span><button id="next-desktop" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">Next</button></nav></div>
            </div>`;
        paginationControls.innerHTML = paginationHTML;
        const prevButton = document.getElementById('prev-desktop');
        const nextButton = document.getElementById('next-desktop');
        prevButton.disabled = currentPage === 1;
        if (prevButton) prevButton.onclick = () => fetchUsers(currentPage - 1);
        nextButton.disabled = currentPage === totalPages;
        if (nextButton) nextButton.onclick = () => fetchUsers(currentPage + 1);
    };
    
    // --- DATA FETCHING ---
    const fetchUsers = async (page = 1) => {
        if (loadingRow) loadingRow.style.display = 'table-row';
        tableBody.innerHTML = '';
        let url = `${apiEndpoint}?page=${page}&limit=10`;
        if (currentSearchQuery) url += `&search=${encodeURIComponent(currentSearchQuery)}`;
        try {
            const token = getToken();
            if (!token) throw new Error('Authentication token not found.');
            const response = await fetch(url, { headers: { 'Authorization': `Bearer ${token}` } });
            if (!response.ok) { 
                if (response.status === 401) window.location.href = '/admin'; 
                throw new Error('Failed to fetch users.'); 
            }
            const { data, totalItems, currentPage: apiCurrentPage, totalPages: apiTotalPages } = await response.json();
            if (loadingRow) loadingRow.style.display = 'none';
            currentPage = apiCurrentPage;
            totalPages = apiTotalPages;
            renderTable(data);
            renderPagination(totalItems);
        } catch (error) {
            console.error('Error fetching users:', error);
            if (loadingRow) loadingRow.style.display = 'none';
            tableBody.innerHTML = `<tr><td colspan="4" class="px-6 py-12 text-center text-red-500">Error: ${error.message}</td></tr>`;
        }
    };

    // --- EVENT LISTENERS ---
    searchInput.addEventListener('keyup', (e) => {
        clearTimeout(debounceTimer);
        const searchTerm = e.target.value;
        debounceTimer = setTimeout(() => {
            if (searchTerm !== currentSearchQuery) {
                currentSearchQuery = searchTerm;
                fetchUsers(1); 
            }
        }, 300);
    });

    tableBody.addEventListener('change', async (e) => {
        const target = e.target;
        if (target.classList.contains('role-change-select')) {
            const id = target.dataset.id;
            const newRole = target.value;
            try {
                const response = await fetch(`${apiEndpoint}/${id}/role`, {
                    method: 'PUT',
                    headers: { 
                        'Authorization': `Bearer ${getToken()}`,
                        'Content-Type': 'application/json' 
                    },
                    body: JSON.stringify({ role: newRole })
                });
                const result = await response.json();
                if (!response.ok) throw new Error(result.message || 'Failed to update role.');
                showToast(result.message, 'success');
            } catch (error) {
                showToast(`Error: ${error.message}`, 'error');
                fetchUsers(currentPage); // Revert select
            }
        }
    });

    tableBody.addEventListener('click', async (e) => {
        const target = e.target;
        if (target.classList.contains('delete-user-btn')) {
            const id = target.dataset.id;
            if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
                try {
                    const response = await fetch(`${apiEndpoint}/${id}`, { 
                        method: 'DELETE', 
                        headers: { 'Authorization': `Bearer ${getToken()}` } 
                    });
                    const result = await response.json();
                    if (!response.ok) throw new Error(result.message || 'Failed to delete user.');
                    document.getElementById(`row-${id}`).remove();
                    showToast('User deleted successfully.', 'success');
                    fetchUsers(currentPage);
                } catch (error) { 
                    showToast(`Error: ${error.message}`, 'error'); 
                }
            }
        }
    });

    // --- INITIAL FETCH ---
    fetchUsers(currentPage);
</script>

<%- include('partials/_footer') %>
